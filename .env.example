# ===== PedaClic — Modèle de variables d'environnement =====
# Copiez ce fichier en « .env » puis renseignez vos valeurs réelles.
#   cp .env.example .env
# IMPORTANT : ne committez JAMAIS le fichier .env (il est dans .gitignore).
#
# NB : avec Vite, toute variable préfixée par VITE_ est INJECTÉE dans le
# bundle client et donc PUBLIQUE. N'y mettez aucun secret serveur
# (clé privée, service account, token admin). La sécurité repose sur les
# règles Firestore/Storage et la restriction des clés, pas sur leur secret.

# --- Configuration Firebase (clés Web — publiques par conception) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- reCAPTCHA (clé de site publique, côté client uniquement) ---
VITE_RECAPTCHA_SITE_KEY=

# --- Tarifs Premium (en FCFA) ---
VITE_MONTHLY_PRICE=
VITE_YEARLY_PRICE=
