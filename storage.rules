rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isAdmin() {
      return request.auth != null && 
             firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    /** Rôle applicatif (users/{uid}) — utilisé par les règles Storage qui s'alignent sur Firestore. */
    function userRole() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role;
    }

    /** Admin ou professeur (pour médias cahiers, médiathèque, etc.). */
    function isProfOrAdmin() {
      return request.auth != null && userRole() in ['admin', 'prof'];
    }
    
    match /ressources/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
      allow delete: if isAdmin();
    }

    match /ebooks/pdf/{fileName} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /ebooks/covers/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ebooks/previews/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /* ==================== EBOOKS HTML (Phase 20+) ====================
       Ebooks publiés sous forme de page HTML autonome (fiche interactive,
       infographie, etc.). Mêmes restrictions que les PDF :
         - lecture : tout utilisateur authentifié (le viewer côté client
           contrôle ensuite l'accès Premium / l'écran de blocage) ;
         - écriture : admin uniquement ;
         - taille max 5 Mo (largement suffisant pour une page HTML
           autonome avec CSS et JS embarqués — la page d'exemple
           Wangrin fait ~80 Ko).
       Le contentType doit être text/html (text/htm accepté en variante). */
    match /ebooks/html/{fileName} {
      allow read: if request.auth != null;
      allow write: if isAdmin()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('text/html.*');
    }

    /* ==================== CAHIER DE TEXTES — pièces jointes ====================
       Chemin côté app : cahiers/{profId}/{entreeId|sous-dossier}/{fichier}
       (MediaPlayer : entreeId ; uploadPieceJointe : cahierId — même motif à 3 segments.)
       Lecture : tout utilisateur authentifié (élèves inclus).
       Écriture / suppression : admin ou prof, avec restriction prof → son seul profId.
       Plafond 50 Mo (aligné MediaPlayer / cahierTextesService). */
    match /cahiers/{profId}/{entreeId}/{fichier} {
      allow read: if request.auth != null;
      allow write: if isProfOrAdmin()
        && (userRole() == 'admin' || request.auth.uid == profId)
        && request.resource.size < 50 * 1024 * 1024;
      allow delete: if isProfOrAdmin()
        && (userRole() == 'admin' || request.auth.uid == profId);
    }

    match /cours-images/{coursId}/{allSubPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    /* ==================== PHASE 27 — MÉDIATHÈQUE ==================== */
    match /mediatheque/videos/{disciplineId}/{mediaId}/{fichier} {
      allow read: if true;
      allow write: if
        request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'prof']
        && request.resource.contentType.matches('video/.*')
        && request.resource.size < 500 * 1024 * 1024;
    }

    match /mediatheque/audios/{disciplineId}/{mediaId}/{fichier} {
      allow read: if true;
      allow write: if
        request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'prof']
        && request.resource.contentType.matches('audio/.*')
        && request.resource.size < 100 * 1024 * 1024;
    }

    match /mediatheque/webinaires/{annee}/{mediaId}/{fichier} {
      allow read: if true;
      allow write: if
        request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'prof']
        && request.resource.contentType.matches('video/.*')
        && request.resource.size < 2 * 1024 * 1024 * 1024;
    }

    match /mediatheque/thumbnails/{mediaId}/{fichier} {
      allow read: if true;
      allow write: if
        request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'prof']
        && request.resource.contentType.matches('image/.*')
        && request.resource.size < 5 * 1024 * 1024;
    }

    /* ==================== QUIZ AVANCÉ — SUPPORTS DE COMPRÉHENSION ORALE ====================
       Supports audio/vidéo attachés aux questions de quiz avancé.
       Chemin : quiz-media/{auteurId}/{fichier}
         - lecture  : tout utilisateur authentifié (élèves inclus, pour passer le quiz) ;
         - écriture : admin (n'importe où) ou prof (son seul dossier auteurId) ;
         - contentType audio/* ou video/* ; plafond 200 Mo. */
    match /quiz-media/{auteurId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if isProfOrAdmin()
        && (userRole() == 'admin' || request.auth.uid == auteurId)
        && (request.resource.contentType.matches('audio/.*')
            || request.resource.contentType.matches('video/.*'))
        && request.resource.size < 200 * 1024 * 1024;
      allow delete: if isProfOrAdmin()
        && (userRole() == 'admin' || request.auth.uid == auteurId);
    }

    /* ==================== QUIZ AVANCÉ — RÉPONSES VOCALES DES ÉLÈVES ====================
       Enregistrements audio produits par l'élève pendant un quiz.
       Chemin : quiz-reponses-audio/{userId}/{questionId}/{fichier}
         - écriture : l'élève propriétaire uniquement (audio/*, plafond 25 Mo) ;
         - lecture  : le propriétaire OU un prof/admin (pour la correction orale). */
    match /quiz-reponses-audio/{userId}/{allPaths=**} {
      allow read: if request.auth != null
        && (request.auth.uid == userId || isProfOrAdmin());
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.contentType.matches('audio/.*')
        && request.resource.size < 25 * 1024 * 1024;
      allow delete: if request.auth != null
        && (request.auth.uid == userId || isProfOrAdmin());
    }

  }
}
