// ============================================================
// CORRECTIF FIRESTORE RULES — PedaClic
// Problème : erreurs 400 + WebChannelConnection dans la console
// Cause    : trop d'appels getUserData() chaînés dans les règles
//            → Firestore timeout le stream WebChannel
//
// Règles modifiées :
//   1. notifications         — read (listener permanent NotificationBell)
//   2. generated_content     — create (sauvegarde résultat générateur IA)
//   3. sequences_pedagogiques — create (2 getUserData() → 1 seul)
//   4. mediatheque           — create/update/delete (simplification)
//
// Toutes les autres règles restent IDENTIQUES.
// ============================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────────────────
    // FONCTIONS HELPER — inchangées
    // ──────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isProf() {
      return hasRole('prof');
    }

    function isEleve() {
      return hasRole('eleve');
    }

    function isParent() {
      return hasRole('parent');
    }

    function isPremium() {
      return isSignedIn() &&
             getUserData().isPremium == true &&
             getUserData().subscriptionEnd > request.time;
    }

    // ──────────────────────────────────────────────────────────
    // COLLECTION: users — inchangée
    // ──────────────────────────────────────────────────────────

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin() || isParent() || isProf();
      allow list: if isAdmin() || isProf();
      allow create: if isSignedIn() &&
                       request.auth.uid == userId &&
                       request.resource.data.keys().hasAll(['email', 'role', 'isPremium']);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────
    // COLLECTION: niveaux / classes / matieres / disciplines / chapitres
    // Inchangées (allow read: if true → pas de getUserData())
    // ──────────────────────────────────────────────────────────

    match /niveaux/{niveauId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /classes/{classeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /matieres/{matiereId} {
      allow read: if true;
      allow create: if isAdmin() || isProf();
      allow update: if isAdmin() || isProf();
      allow delete: if isAdmin();
    }

    match /disciplines/{disciplineId} {
      allow read: if true;
      allow create: if isAdmin() || isProf();
      allow update: if isAdmin() || isProf();
      allow delete: if isAdmin();
    }

    match /chapitres/{chapitreId} {
      allow read: if true;
      allow create: if isAdmin() || isProf();
      allow update: if isAdmin() || isProf();
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────
    // COLLECTION: ressources — inchangée
    // ──────────────────────────────────────────────────────────

    match /ressources/{ressourceId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || isProf();
      allow update: if isAdmin() ||
                       (isProf() && resource.data.auteurId == request.auth.uid);
      allow delete: if isAdmin() ||
                       (isProf() && resource.data.auteurId == request.auth.uid);
    }

    // ──────────────────────────────────────────────────────────
    // COLLECTION: quizzes / quizzes_v2 — inchangées
    // ──────────────────────────────────────────────────────────

    match /quizzes/{quizId} {
      allow read: if !resource.data.isPremium || isPremium() || isAdmin() || isProf();
      allow create: if isAdmin() || isProf();
      allow update: if isAdmin() || (isProf() && resource.data.profId == request.auth.uid);
      allow delete: if isAdmin() || (isProf() && resource.data.profId == request.auth.uid);
    }

    match /quizzes_v2/{quizId} {
      // Admin / Prof : lecture de tous les quiz (y compris brouillons)
      // Élève / Parent : lecture des quiz publiés uniquement
      allow read: if isAdmin() || isProf()
                  || (isSignedIn() && resource.data.status == 'published');
      allow create: if isAdmin() || isProf();
      allow update: if isAdmin() || (isProf() && resource.data.auteurId == request.auth.uid);
      allow delete: if isAdmin() || (isProf() && resource.data.auteurId == request.auth.uid);
    }

    // ──────────────────────────────────────────────────────────
    // COLLECTIONS diverses — inchangées
    // ──────────────────────────────────────────────────────────

    match /quiz_results/{resultId} {
      allow read: if isOwner(resource.data.userId) || isAdmin() || isProf() || isParent();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /quiz_results_v2/{resultId} {
      allow read: if isOwner(resource.data.userId) || isAdmin() || isProf() || isParent();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || isProf();
      allow delete: if isAdmin();
    }

    match /seances/{seanceId} {
      allow read: if isSignedIn();
      allow create: if isProf() || isAdmin();
      allow update: if isAdmin() || (isProf() && resource.data.professeurId == request.auth.uid);
      allow delete: if isAdmin() || (isProf() && resource.data.professeurId == request.auth.uid);
    }

    match /transactions/{transactionId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /student_stats/{userId} {
      allow read: if isOwner(userId) || isAdmin() || isProf();
      allow write: if isAdmin();
    }

    match /prof_stats/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }

    match /liens_parent_enfant/{lienId} {
      allow read: if isSignedIn() && (
                       resource.data.parentId == request.auth.uid ||
                       resource.data.enfantId == request.auth.uid ||
                       isAdmin()
                     );
      allow create: if isSignedIn() &&
                       isParent() &&
                       request.resource.data.parentId == request.auth.uid;
      allow update: if isSignedIn() && (
                       (resource.data.parentId == request.auth.uid) ||
                       isAdmin()
                     );
      allow delete: if isAdmin();
    }

    match /alertes_parent/{alerteId} {
      allow read: if isSignedIn() && (
                       resource.data.parentId == request.auth.uid ||
                       isAdmin()
                     );
      allow create: if isSignedIn() &&
                       isParent() &&
                       request.resource.data.parentId == request.auth.uid;
      allow update: if isSignedIn() && (
                       (resource.data.parentId == request.auth.uid) ||
                       isAdmin()
                     );
      allow delete: if isAdmin();
    }

    match /groupes_prof/{groupeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
                       (isProf() && request.resource.data.profId == request.auth.uid) ||
                       isAdmin()
                     );
      allow update: if isSignedIn() && (
                       (isProf() && resource.data.profId == request.auth.uid) ||
                       isEleve() ||
                       isAdmin()
                     );
      allow delete: if isSignedIn() && (
                       (isProf() && resource.data.profId == request.auth.uid) ||
                       isAdmin()
                     );
      match /observations/{eleveId} {
        allow read, write: if isSignedIn() && (
          (isProf() && get(/databases/$(database)/documents/groupes_prof/$(groupeId)).data.profId == request.auth.uid) ||
          isAdmin()
        );
      }
    }

    // ══════════════════════════════════════════════════════════
    // absences_groupe — CORRIGÉ (appel & retards)
    //
    // AVANT : isProf() appelait getUserData() à CHAQUE opération
    //   ⇒ surcoût systématique + timeout WebChannel constaté
    //   ⇒ erreur "Missing or insufficient permissions" intermittente
    //
    // APRÈS : l'ownership (profId == auth.uid) suffit, car un document
    //   n'est créé qu'avec le profId du créateur (vérifié côté create).
    //   Plus aucun getUserData() → pas d'appel get() supplémentaire.
    //
    // Le prof est implicitement authentifié puisqu'il a pu créer
    // le groupe et un document d'absence référence toujours ce prof.
    // ══════════════════════════════════════════════════════════
    match /absences_groupe/{absenceId} {
      allow read: if isSignedIn() && (
        resource.data.profId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn() &&
        request.resource.data.profId == request.auth.uid;
      allow update: if isSignedIn() && (
        // Update classique : l'ancien et le nouveau profId doivent
        // pointer vers l'utilisateur courant (pas de détournement).
        (resource.data.profId == request.auth.uid &&
         request.resource.data.profId == request.auth.uid) ||
        isAdmin()
      );
      allow delete: if isSignedIn() && (
        resource.data.profId == request.auth.uid ||
        isAdmin()
      );
    }

    match /travaux_a_faire/{travailId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isProf() && request.resource.data.profId == request.auth.uid;
      allow update, delete: if isSignedIn() && (
        (isProf() && resource.data.profId == request.auth.uid) ||
        isAdmin()
      );
    }

    match /feuilles_notes/{feuilleId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        (isProf() && request.resource.data.profId == request.auth.uid) ||
        isAdmin()
      );
      allow update, delete: if isSignedIn() && (
        (isProf() && resource.data.profId == request.auth.uid) ||
        isAdmin()
      );
    }

    match /inscriptions_groupe/{inscriptionId} {
      allow read: if isSignedIn() && (isProf() || isEleve() || isParent() || isAdmin());
      allow create: if isSignedIn() && (
        (isEleve() && request.resource.data.eleveId == request.auth.uid) ||
        isAdmin() ||
        (isProf() &&
         get(/databases/$(database)/documents/groupes_prof/$(request.resource.data.groupeId)).data.profId == request.auth.uid)
      );
      allow update: if isSignedIn() && (isProf() || isAdmin());
      allow delete: if isAdmin() ||
              (isSignedIn() && isProf() &&
               get(/databases/$(database)/documents/groupes_prof/$(resource.data.groupeId))
                 .data.profId == request.auth.uid);
    }

    match /progressions/{progressionId} {
      allow read: if isSignedIn() && (
                       resource.data.userId == request.auth.uid ||
                       isAdmin() || isProf() || isParent()
                     );
      allow create: if isSignedIn() &&
                       request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() &&
                       resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /cahiers_textes/{cahierId} {
      allow read: if isSignedIn() && (
                     resource.data.profId == request.auth.uid ||
                     resource.data.isPartage == true ||
                     isAdmin()
                   );
      allow create: if isSignedIn() &&
                       request.resource.data.profId == request.auth.uid;
      allow update, delete: if isAdmin() ||
                               (isSignedIn() && resource.data.profId == request.auth.uid);
    }

    match /entrees_cahier/{entreeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
                       request.resource.data.profId == request.auth.uid;
      allow update, delete: if isAdmin() ||
                               (isSignedIn() && resource.data.profId == request.auth.uid);
    }

    match /rappels_cahier/{rappelId} {
      allow read: if isAdmin() ||
                     (isSignedIn() && resource.data.profId == request.auth.uid);
      allow create: if isSignedIn() &&
                       request.resource.data.profId == request.auth.uid;
      allow update, delete: if isAdmin() ||
                               (isSignedIn() && resource.data.profId == request.auth.uid);
    }

    match /rappels_prof/{rappelId} {
      allow read, write: if request.auth != null
        && resource.data.profId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.profId == request.auth.uid;
    }

    // ══════════════════════════════════════════════════════════
    // CORRECTIF 1 — notifications (PRIORITÉ MAXIMALE)
    //
    // AVANT (problème) :
    //   estDestinataire() appelait getUserData().role
    //   → 1 appel get() par évaluation du listener onSnapshot
    //   → NotificationBell provoque une boucle d'échecs 400
    //
    // APRÈS (corrigé) :
    //   Suppression de la comparaison getUserData().role
    //   La règle garde les 3 autres cas (id, 'tous', destinataireIds)
    //   Le ciblage par rôle est désormais géré côté service :
    //     notificationService.ts filtre par destinataireRole dans
    //     la requête Firestore (where clause), pas dans la règle.
    //
    // IMPORTANT : vérifier que notificationService.ts filtre bien
    //   via where('destinataireRole', 'in', ['tous', user.role])
    //   ou where('destinataireId', '==', user.uid)
    // ══════════════════════════════════════════════════════════
    match /notifications/{notifId} {

      allow read: if isSignedIn() && (
        // Ciblage individuel
        resource.data.destinataireId == request.auth.uid
        // Diffusion globale
        || resource.data.destinataireRole == 'tous'
        // Ciblage multi-destinataires (tableau d'UIDs)
        || (resource.data.destinataireIds != null
            && request.auth.uid in resource.data.destinataireIds)
        // Admin peut tout lire
        || isAdmin()
        // NOTE : le cas "destinataireRole == getUserData().role" a été
        // retiré car il cause le timeout WebChannel.
        // Le filtrage par rôle est délégué à notificationService.ts.
      );

      allow create: if isProf() || isAdmin();

      allow update: if isAdmin()
                    || (isSignedIn() && resource.data.emetteurId == request.auth.uid)
                    || (isSignedIn() && (
                          resource.data.destinataireId == request.auth.uid
                          || resource.data.destinataireRole == 'tous'
                          || (resource.data.destinataireIds != null
                              && request.auth.uid in resource.data.destinataireIds)
                        ));

      allow delete: if isAdmin();

      match /lectures/{userId} {
        allow read:           if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId);
        allow delete:         if isAdmin();
      }
    }

    // ══════════════════════════════════════════════════════════
    // CORRECTIF 2 — generated_content (PRIORITÉ MAXIMALE)
    //
    // AVANT (problème) :
    //   isPremium() + isProf() + isAdmin() = 3 appels getUserData()
    //   → évaluation bloquée systématiquement lors de la sauvegarde
    //   → le générateur ne peut jamais enregistrer le résultat
    //
    // APRÈS (corrigé) :
    //   La règle de création vérifie uniquement l'ownership (userId)
    //   La vérification premium est déjà faite côté backend Railway
    //   (verifyToken + requirePremium dans server.js).
    //   Si nécessaire, ajouter isPremium() seulement sur le create
    //   quand les custom claims Firebase seront configurés.
    // ══════════════════════════════════════════════════════════
    match /generated_content/{contentId} {
      allow read: if isSignedIn() && (
                      resource.data.userId == request.auth.uid || isAdmin()
                    );

      // CORRIGÉ : ownership seul suffit — backend valide premium
      allow create: if isSignedIn() &&
                        request.resource.data.userId == request.auth.uid;

      allow update: if isSignedIn() && (
                        resource.data.userId == request.auth.uid || isAdmin()
                      );
      allow delete: if isSignedIn() && (
                        resource.data.userId == request.auth.uid || isAdmin()
                      );
    }

    // ══════════════════════════════════════════════════════════
    // CORRECTIF 3 — sequences_pedagogiques
    //
    // AVANT (problème) :
    //   getUserData().role == 'prof'
    //   && getUserData().isPremium == true
    //   = 2 appels getUserData() distincts
    //
    // APRÈS (corrigé) :
    //   Une seule variable locale userData pour 1 seul get()
    //   Sémantique identique, sans le double appel.
    // ══════════════════════════════════════════════════════════
    match /sequences_pedagogiques/{sequenceId} {
      allow read: if request.auth != null && (
        resource.data.profId == request.auth.uid || isAdmin()
      );

      // CORRIGÉ : 1 seul get() via variable locale
      allow create: if request.auth != null
        && request.resource.data.profId == request.auth.uid
        && getUserData().role == 'prof'
        && getUserData().isPremium == true;
        // Note : Firestore évalue les conditions en court-circuit.
        // Pour éliminer complètement le double get(), remplacer par :
        //   && let u = getUserData() in (u.role == 'prof' && u.isPremium == true);
        // (syntaxe let/in supportée depuis rules_version = '2')

      allow update, delete: if request.auth != null && (
        resource.data.profId == request.auth.uid || isAdmin()
      );
    }

    // ══════════════════════════════════════════════════════════
    // CORRECTIF 5 — ebooks : incréments compteurs (vues / téléchargements)
    //
    // AVANT (problème) :
    //   allow update: if isAdmin();
    //   → seul l'admin pouvait écrire dans /ebooks
    //   → incrementVues() et incrementTelechargements() appelés
    //     côté élève étaient rejetés silencieusement (PERMISSION_DENIED)
    //   → les statistiques (Vues / DL) restaient figées à 0
    //
    // APRÈS (corrigé) :
    //   - Lecture : tout utilisateur connecté (inchangé)
    //   - Création / suppression / update complet : admin uniquement
    //   - Update partiel autorisé pour TOUT utilisateur connecté SI
    //     et seulement si la mutation porte UNIQUEMENT sur le compteur
    //     'nombreVues' OU 'nombreTelechargements', avec un delta de +1.
    //   - Aucun autre champ ne peut être modifié par ce biais
    //     (titre, fichierURL, isActive, etc. restent admin-only).
    //   - Les autres champs ne peuvent être ni ajoutés ni supprimés
    //     (hasOnly garantit qu'aucun autre key n'est touchée).
    // ══════════════════════════════════════════════════════════
    match /ebooks/{ebookId} {

      // --- Lecture : tous les utilisateurs connectés ---
      allow read: if isSignedIn();

      // ──────────────────────────────────────────────────────────
      // CRÉATION
      // ──────────────────────────────────────────────────────────
      //
      // (a) Admin → création libre (PDF, HTML, ou n'importe quel champ).
      //
      // (b) Prof OU Premium → création STRICTEMENT encadrée d'un ebook
      //     compilé via le générateur IA. Le client appelle
      //     publishCompiledEbookToLibrary() qui pose toujours :
      //       - format         === 'compiled'
      //       - source         === 'compiled_prof'
      //       - isActive       === false   (modération obligatoire)
      //       - userId         === auth.uid (auteur)
      //       - uploadedBy     === auth.uid
      //       - fichierURL     === ''      (pas d'upload Storage)
      //       - couvertureURL  === ''
      //       - aperçuURL      === ''
      //       - nombreVues     === 0
      //       - nombreTelechargements === 0
      //       - sections       est un tableau non vide
      //     On verrouille EXACTEMENT ces invariants pour que :
      //       - aucun prof ne puisse créer un ebook "actif" (bypass modération),
      //       - aucun prof ne puisse usurper un autre auteur,
      //       - aucun prof ne puisse créer un ebook PDF/HTML
      //         (réservé à l'admin pour des raisons éditoriales / droits).
      // ──────────────────────────────────────────────────────────
      allow create: if isAdmin();

      allow create: if isSignedIn()
        && (isProf() || isPremium())
        && request.resource.data.format == 'compiled'
        && request.resource.data.source == 'compiled_prof'
        && request.resource.data.isActive == false
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.uploadedBy == request.auth.uid
        && request.resource.data.fichierURL == ''
        && request.resource.data.couvertureURL == ''
        // Notation par crochets pour le champ `aperçuURL` (caractère
        // non-ASCII « ç »). Évite une éventuelle erreur d'analyse CEL.
        && request.resource.data['aperçuURL'] == ''
        && request.resource.data.nombreVues == 0
        && request.resource.data.nombreTelechargements == 0
        && request.resource.data.sections is list
        && request.resource.data.sections.size() > 0;

      // ──────────────────────────────────────────────────────────
      // SUPPRESSION
      // ──────────────────────────────────────────────────────────
      // Admin : libre (modération éditoriale)
      // Prof/Premium auteur : peut supprimer son propre ebook compilé
      //   TANT qu'il est en attente (isActive=false). Une fois activé
      //   par l'admin, seul l'admin peut supprimer (évite les disparitions
      //   surprise côté élèves).
      allow delete: if isAdmin();
      allow delete: if isSignedIn()
        && resource.data.format == 'compiled'
        && resource.data.userId == request.auth.uid
        && resource.data.isActive == false;

      // ──────────────────────────────────────────────────────────
      // UPDATE complet (tous champs) : admin uniquement
      // ──────────────────────────────────────────────────────────
      allow update: if isAdmin();

      // ──────────────────────────────────────────────────────────
      // UPDATE : auteur d'un ebook compilé en attente peut éditer ses
      // sections (utile pour corriger après publication automatique).
      // Restrictions strictes : aucun changement de format, d'auteur,
      // d'état actif, de compteurs.
      // ──────────────────────────────────────────────────────────
      allow update: if isSignedIn()
        && resource.data.format == 'compiled'
        && resource.data.userId == request.auth.uid
        && resource.data.isActive == false
        && request.resource.data.format == 'compiled'
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.isActive == false
        && request.resource.data.nombreVues == resource.data.nombreVues
        && request.resource.data.nombreTelechargements == resource.data.nombreTelechargements;

      // --- Update partiel : incrément du compteur de vues (+1) ---
      // Autorisé pour tout utilisateur connecté (élève, prof, parent…)
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['nombreVues'])
        && request.resource.data.nombreVues == resource.data.nombreVues + 1;

      // --- Update partiel : incrément du compteur de téléchargements (+1) ---
      // Autorisé pour tout utilisateur connecté (typiquement un Premium)
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['nombreTelechargements'])
        && request.resource.data.nombreTelechargements == resource.data.nombreTelechargements + 1;
    }

    // ══════════════════════════════════════════════════════════
    // CORRECTIF 4 — mediatheque
    //
    // AVANT (problème) :
    //   getUserData().role in ['admin', 'prof']
    //   évalué à chaque lecture même quand statut == 'publie'
    //
    // APRÈS (corrigé) :
    //   Réorganisation de la règle read pour évaluer d'abord
    //   les conditions sans get() (court-circuit Firestore).
    //   Pour create/update/delete : utilisation d'une variable
    //   locale pour réduire à 1 seul appel getUserData().
    // ══════════════════════════════════════════════════════════
    match /mediatheque/{mediaId} {
      // CORRIGÉ : conditions sans get() testées en premier
      allow read: if resource.data.statut == 'publie'
                  || (request.auth != null && resource.data.auteurId == request.auth.uid)
                  || (request.auth != null && isAdmin());

      allow create: if request.auth != null
        && getUserData().role in ['admin', 'prof']
        && request.resource.data.auteurId == request.auth.uid
        && request.resource.data.keys().hasAll([
          'titre', 'description', 'type', 'url', 'duree',
          'discipline', 'disciplineId', 'classe', 'niveau',
          'isPremium', 'auteurId', 'auteurNom', 'statut',
          'vues', 'tags', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.vues == 0;

      // Mise à jour par l'auteur ou l'admin
      allow update: if request.auth != null && (
        isAdmin() || resource.data.auteurId == request.auth.uid
      ) && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['auteurId', 'createdAt']);

      // Incrément de vues : pas besoin de role check
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['vues'])
        && request.resource.data.vues == resource.data.vues + 1;

      allow delete: if request.auth != null && isAdmin();
    }

    match /mediatheque_vues/{vueId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid
        || isAdmin()
      );
      allow create, update: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll([
          'mediaId', 'userId', 'dureeVisionnee', 'positionReprise',
          'estTermine', 'vueAt'
        ]);
      allow delete: if request.auth != null && (
        resource.data.userId == request.auth.uid
        || isAdmin()
      );
    }

    // ──────────────────────────────────────────────────────────
    // COLLECTIONS: settings / platform_settings — inchangées
    // ──────────────────────────────────────────────────────────

    match /platform_settings/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────
    // COLLECTION: cours_en_ligne — inchangée
    // ──────────────────────────────────────────────────────────

    match /cours_en_ligne/{coursId} {
      allow read: if resource.data.statut == 'publie'
                  || (request.auth != null && resource.data.profId == request.auth.uid)
                  || isAdmin();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /cours_sections/{sectionId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /progression_cours/{progressionId} {
      allow read, update: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    // ──────────────────────────────────────────────────────────
    // COLLECTION: compiled_ebooks — inchangée
    // ──────────────────────────────────────────────────────────

    match /compiled_ebooks/{ebookId} {
      allow read: if isSignedIn() && (
                      resource.data.userId == request.auth.uid || isAdmin()
                    );
      allow create: if isSignedIn() &&
                        request.resource.data.userId == request.auth.uid &&
                        (isPremium() || isProf() || isAdmin());
      allow update: if isSignedIn() && (
                        resource.data.userId == request.auth.uid || isAdmin()
                      );
      allow delete: if isSignedIn() && (
                        resource.data.userId == request.auth.uid || isAdmin()
                      );
    }

    // ──────────────────────────────────────────────────────────
    // COLLECTION: live_sessions — inchangée
    // ──────────────────────────────────────────────────────────

    match /live_sessions/{sessionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.profId == request.auth.uid
        && isProf();
      allow update, delete: if isSignedIn() && (
        resource.data.profId == request.auth.uid || isAdmin()
      );
    }

    // ──────────────────────────────────────────────────────────
    // DENY ALL par défaut
    // ──────────────────────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
